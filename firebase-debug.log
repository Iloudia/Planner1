[debug] [2026-04-14T14:42:44.475Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/meandrituals-72041/rulesets {"name":"projects/meandrituals-72041/rulesets/068485af-a6f8-4349-a97a-fa32a5a2704f","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function hasAdminClaim() {\n      return isSignedIn() &&\n        (request.auth.token.admin == true || request.auth.token.role == \"admin\");\n    }\n\n    function hasAdminEmail() {\n      return isSignedIn() &&\n        (request.auth.token.email == \"contact@meandrituals.com\" ||\n          request.auth.token.email == \"iloudiav@gmail.com\");\n    }\n\n    function hasAdminDocument() {\n      return isSignedIn() &&\n        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;\n    }\n\n    function isAdmin() {\n      return hasAdminClaim() || hasAdminEmail() || hasAdminDocument();\n    }\n\n    function isPlannerCollection(collectionName) {\n      return collectionName == \"calendarEvents\" ||\n        collectionName == \"journalEntries\" ||\n        collectionName == \"financeEntries\" ||\r\n        collectionName == \"financeMonthlySnapshots\" ||\r\n        collectionName == \"wishlistCategories\" ||\r\n        collectionName == \"wishlistItems\" ||\r\n        collectionName == \"sportDashboard\" ||\r\n        collectionName == \"sportWeeklyBoards\" ||\r\n        collectionName == \"workoutExercises\" ||\r\n        collectionName == \"workoutSeries\" ||\r\n        collectionName == \"workoutVideos\" ||\r\n        collectionName == \"workoutSettings\" ||\r\n        collectionName == \"selfLoveDraft\" ||\r\n        collectionName == \"selfLovePhotos\" ||\r\n        collectionName == \"bodyGoalPhotos\" ||\r\n        collectionName == \"selfLoveQualities\" ||\r\n        collectionName == \"selfLoveThoughts\" ||\r\n        collectionName == \"selfLoveArchiveEntries\" ||\r\n        collectionName == \"routineItems\" ||\r\n        collectionName == \"goalsDailyTrackers\" ||\r\n        collectionName == \"dietWeeklyPlans\" ||\r\n        collectionName == \"dietCustomRecipes\" ||\r\n        collectionName == \"dietPreferences\";\r\n    }\n\n    match /users/{userId} {\n      allow list: if isAdmin();\n      allow get: if isOwner(userId) || isAdmin();\n      allow create, update, delete: if isOwner(userId);\n\n      match /{collectionName}/{docId} {\n        allow read, write: if isOwner(userId) && isPlannerCollection(collectionName);\n      }\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-04-14T14:42:46.319071Z","metadata":{"services":["cloud.firestore"]}}
