APP_BASE_URL=http://localhost:5173
API_PUBLIC_BASE_URL=http://127.0.0.1:4242
HOST=127.0.0.1
PORT=4242
TRUST_PROXY=0
# Test mode only for now: use sk_test_ / whsec_ values from Stripe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
DOWNLOAD_TOKEN_SECRET=change-me
RESEND_API_KEY=re_...
EMAIL_FROM=MeAndRituals <no-reply@tondomaine.fr>
CONTACT_EMAIL_TO=contact@meandrituals.com
DOWNLOADS_DIR=C:\\path\\to\\downloads
CUSTOM_PRODUCTS_FILE=C:\\path\\to\\custom-products.json
PURCHASES_FILE=C:\\path\\to\\purchases.json
MEDIA_ROOT_DIR=C:\\path\\to\\media
MEDIA_PUBLIC_BASE_URL=/media
CORS_ORIGINS=http://localhost:5173
ADMIN_EMAILS=admin@tondomaine.fr

FIREBASE_PROJECT_ID=meandrituals-72041
# Required for real admin-side account deletion.
# Prefer a single JSON payload or base64-encoded JSON from a Firebase service account.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
# FIREBASE_ADMIN_SERVICE_ACCOUNT_BASE64=
# FIREBASE_ADMIN_PROJECT_ID=meandrituals-72041
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Optional in local dev. In production, prefer same-origin /api and /media behind Nginx.
VITE_API_BASE=http://127.0.0.1:4242
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
