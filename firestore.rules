rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasAdminClaim() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == "admin");
    }

    function hasAdminEmail() {
      return isSignedIn() &&
        (request.auth.token.email == "contact@meandrituals.com" ||
          request.auth.token.email == "iloudiav@gmail.com");
    }

    function hasAdminDocument() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    function isAdmin() {
      return hasAdminClaim() || hasAdminEmail() || hasAdminDocument();
    }

    function isPlannerCollection(collectionName) {
      return collectionName == "calendarEvents" ||
        collectionName == "journalEntries" ||
        collectionName == "financeEntries" ||
        collectionName == "financeMonthlySnapshots" ||
        collectionName == "wishlistCategories" ||
        collectionName == "wishlistItems" ||
        collectionName == "sportDashboard" ||
        collectionName == "sportWeeklyBoards" ||
        collectionName == "workoutExercises" ||
        collectionName == "workoutSeries" ||
        collectionName == "workoutVideos" ||
        collectionName == "workoutSettings" ||
        collectionName == "selfLoveDraft" ||
        collectionName == "selfLovePhotos" ||
        collectionName == "bodyGoalPhotos" ||
        collectionName == "selfLoveQualities" ||
        collectionName == "selfLoveThoughts" ||
        collectionName == "selfLoveArchiveEntries" ||
        collectionName == "routineItems" ||
        collectionName == "goalsDailyTrackers" ||
        collectionName == "dietWeeklyPlans" ||
        collectionName == "dietCustomRecipes" ||
        collectionName == "dietPreferences";
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isOwner(userId);

      match /{collectionName}/{docId} {
        allow read, write: if isOwner(userId) && isPlannerCollection(collectionName);
      }
    }
  }
}
